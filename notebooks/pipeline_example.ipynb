# %% [markdown]
# # Credit Card Fraud Detection Pipeline
# 
# This notebook walks through all stages of the ML pipeline:
# 1. Data Loading
# 2. Exploratory Data Analysis (EDA)
# 3. Preprocessing
# 4. Feature Engineering
# 5. Model Training
# 6. Ensembling
# 7. Hyperparameter Tuning
# 8. Deployment Preparation

# %% [markdown]
# ## Setup and Imports

import sys
from pathlib import Path

# Add src directory to path
sys.path.insert(0, str(Path.cwd() / 'src'))

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Set plotting style
plt.style.use('seaborn-v0_8-whitegrid')
sns.set_palette("husl")

print("✅ All imports successful!")

# %% [markdown]
# ## 1. Data Loading

from src.data_loading import load_data, get_data_info

# Load the dataset
df = load_data("data/creditcard.csv")

# Display basic information
get_data_info(df)

# %% [markdown]
# ## 2. Exploratory Data Analysis (EDA)

from src.eda import run_full_eda, plot_class_distribution, plot_correlation_heatmap

# Run complete EDA pipeline
run_full_eda(df, output_dir="notebooks/eda_outputs")

# Or run individual analyses:
# plot_class_distribution(df, save_path="notebooks/eda_outputs/class_dist.png")
# plot_correlation_heatmap(df, save_path="notebooks/eda_outputs/correlation.png")

# %% [markdown]
# ## 3. Preprocessing

from src.preprocessing import preprocess_pipeline, split_data, scale_features, handle_imbalance

# Run complete preprocessing pipeline
preprocessed = preprocess_pipeline(
    df,
    test_size=0.2,
    val_size=0.0,
    scale_method='standard',
    resampling_method='smote',  # Try: 'smote', 'adasyn', 'random_under', 'none'
    random_state=42
)

# Access preprocessed data
X_train = preprocessed['X_train']
y_train = preprocessed['y_train']
X_test = preprocessed['X_test']
y_test = preprocessed['y_test']
scaler = preprocessed['scaler']

print(f"\nTraining set size: {len(X_train):,}")
print(f"Test set size: {len(X_test):,}")
print(f"Class distribution in training set:\n{y_train.value_counts()}")

# Save scaler for deployment
import joblib
joblib.dump(scaler, "models/scaler.joblib")
print("\n✅ Scaler saved to models/scaler.joblib")

# %% [markdown]
# ## 4. Feature Engineering (Optional)

from src.feature_engineering import engineer_features_pipeline

# Create additional features
df_engineered, metadata = engineer_features_pipeline(
    df,
    add_time_features=True,
    add_amount_features=True,
    add_interactions=False,
    apply_pca_transform=False,
    select_k_features=None
)

print(f"\nOriginal features: {len(metadata['original_columns'])}")
print(f"New features added: {len(metadata['added_features'])}")
print(f"Final features: {len(df_engineered.columns)}")

# Re-preprocess with engineered features
preprocessed_eng = preprocess_pipeline(
    df_engineered,
    test_size=0.2,
    resampling_method='smote'
)

X_train = preprocessed_eng['X_train']
y_train = preprocessed_eng['y_train']
X_test = preprocessed_eng['X_test']
y_test = preprocessed_eng['y_test']

# %% [markdown]
# ## 5. Model Training

from src.model_training import train_multiple_models, get_models, train_model

# Train multiple models
results = train_multiple_models(
    X_train, y_train, X_test, y_test,
    model_names=['LogisticRegression', 'RandomForest', 'XGBoost', 'LightGBM'],
    save_dir='models',
    verbose=True
)

# Access individual model results
for model_name, (model, train_metrics, test_metrics) in results.items():
    print(f"\n{model_name} Test ROC-AUC: {test_metrics['ROC-AUC']:.4f}")

# %% [markdown]
# ## 6. Ensembling

from src.ensembling import compare_ensembles, create_voting_classifier, create_stacking_classifier

# Select best models for ensembling
base_models = {
    name: results[name][0] 
    for name in ['RandomForest', 'XGBoost', 'LightGBM'] 
    if name in results
}

# Compare different ensemble strategies
ensemble_comparison = compare_ensembles(
    base_models=base_models,
    X_train=X_train,
    y_train=y_train,
    X_test=X_test,
    y_test=y_test,
    ensemble_types=['voting', 'stacking', 'weighted'],
    save_dir='models'
)

print("\nEnsemble Comparison Results:")
print(ensemble_comparison)

# %% [markdown]
# ## 7. Hyperparameter Tuning

from src.hyperparameter_tuning import tune_with_random_search, optimize_with_optuna

# Quick Random Search for XGBoost
from xgboost import XGBClassifier

param_distributions = {
    'n_estimators': [100, 200, 300],
    'max_depth': [3, 5, 7],
    'learning_rate': [0.05, 0.1, 0.2],
    'scale_pos_weight': [results['XGBoost'][0].scale_pos_weight]
}

best_model, tuning_results = tune_with_random_search(
    model=XGBClassifier(random_state=42, n_jobs=-1, eval_metric='auc'),
    param_distributions=param_distributions,
    X_train=X_train,
    y_train=y_train,
    n_iter=10,
    cv=5,
    scoring='roc_auc',
    save_path='models/xgboost_tuned.joblib',
    verbose=1
)

print(f"\nBest Parameters: {tuning_results['best_params']}")
print(f"Best CV Score: {tuning_results['best_score']:.4f}")

# For more thorough tuning, use Optuna (requires: pip install optuna)
# best_params, best_model = optimize_with_optuna(
#     model_name='XGBoost',
#     X_train=X_train,
#     y_train=y_train,
#     n_trials=50,
#     cv=5,
#     save_path='models/xgboost_optuna.joblib'
# )

# %% [markdown]
# ## 8. Model Evaluation and Comparison

import pandas as pd

# Collect all results
comparison_data = []

for model_name, (model, train_metrics, test_metrics) in results.items():
    comparison_data.append({
        'Model': model_name,
        'Train ROC-AUC': train_metrics['ROC-AUC'],
        'Test ROC-AUC': test_metrics['ROC-AUC'],
        'Test F1': test_metrics['F1 Score'],
        'Test Precision': test_metrics['Precision'],
        'Test Recall': test_metrics['Recall'],
        'Test Accuracy': test_metrics['Accuracy']
    })

comparison_df = pd.DataFrame(comparison_data)
comparison_df = comparison_df.sort_values('Test ROC-AUC', ascending=False)

print("\nModel Comparison Summary:")
print(comparison_df.to_string(index=False))

# Save comparison
comparison_df.to_csv('models/model_comparison_summary.csv', index=False)
print("\n✅ Comparison saved to models/model_comparison_summary.csv")

# %% [markdown]
# ## 9. Visualization of Results

fig, axes = plt.subplots(2, 2, figsize=(14, 10))

# ROC-AUC Comparison
axes[0, 0].barh(comparison_df['Model'], comparison_df['Test ROC-AUC'])
axes[0, 0].set_xlabel('ROC-AUC Score')
axes[0, 0].set_title('Model Comparison - ROC-AUC')
axes[0, 0].set_xlim([0.9, 1.0])

# F1 Score Comparison
axes[0, 1].barh(comparison_df['Model'], comparison_df['Test F1'])
axes[0, 1].set_xlabel('F1 Score')
axes[0, 1].set_title('Model Comparison - F1 Score')

# Precision-Recall Tradeoff
axes[1, 0].scatter(comparison_df['Test Precision'], comparison_df['Test Recall'], 
                   s=100, alpha=0.7)
for i, row in comparison_df.iterrows():
    axes[1, 0].annotate(row['Model'][:3], 
                       (row['Test Precision'], row['Test Recall']),
                       fontsize=9)
axes[1, 0].set_xlabel('Precision')
axes[1, 0].set_ylabel('Recall')
axes[1, 0].set_title('Precision-Recall Tradeoff')

# Training vs Test Performance
x = np.arange(len(comparison_df))
width = 0.35
axes[1, 1].bar(x - width/2, comparison_df['Train ROC-AUC'], width, label='Train')
axes[1, 1].bar(x + width/2, comparison_df['Test ROC-AUC'], width, label='Test')
axes[1, 1].set_xticks(x)
axes[1, 1].set_xticklabels(comparison_df['Model'], rotation=45)
axes[1, 1].set_ylabel('ROC-AUC Score')
axes[1, 1].set_title('Training vs Test Performance')
axes[1, 1].legend()
axes[1, 1].set_ylim([0.9, 1.0])

plt.tight_layout()
plt.savefig('notebooks/eda_outputs/model_comparison.png', dpi=300, bbox_inches='tight')
plt.show()

# %% [markdown]
# ## 10. Save Best Model for Deployment

# Find best model based on test ROC-AUC
best_model_name = comparison_df.iloc[0]['Model']
best_model, _, _ = results[best_model_name]

# Save best model
best_model_path = f'models/best_{best_model_name}_final.joblib'
joblib.dump(best_model, best_model_path)
print(f"\n✅ Best model ({best_model_name}) saved to: {best_model_path}")

# Verify saved models
import os
print("\nSaved models in 'models/' directory:")
for file in os.listdir('models'):
    if file.endswith('.joblib'):
        print(f"  - {file}")

